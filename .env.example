# Landing page environment variables
# Copy to .env and fill in values before running `npm run dev`.

# Base URL of the Flask backend that receives beta-form POSTs (/api/waitlist).
# Defaults to http://localhost:5000 when unset.
PUBLIC_API_URL=http://localhost:5000

# PostHog EU project API key (public). Get it from https://eu.posthog.com → Project settings.
# Leave unset to disable analytics in local dev.
PUBLIC_POSTHOG_KEY=phc_xxx
