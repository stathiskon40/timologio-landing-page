# Landing page environment variables
# Copy to .env and fill in values before running `npm run dev`.

# --- Waitlist signup (Supabase Edge Function + Cloudflare Turnstile) ---
# The beta form POSTs to the `waitlist-signup` Edge Function directly; no Flask
# backend is involved. Turnstile gates the function against spam.

# Supabase project URL (used to build the Edge Function endpoint).
PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key — required by the Supabase gateway for public Edge Functions.
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Cloudflare Turnstile site key. Create a widget at
# https://dash.cloudflare.com/?to=/:account/turnstile and copy the SITE key here.
# The corresponding SECRET key must be set as a Supabase secret named
# TURNSTILE_SECRET_KEY (see: supabase secrets set TURNSTILE_SECRET_KEY=...).
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...

# PostHog EU project API key (public). Get it from https://eu.posthog.com → Project settings.
# Leave unset to disable analytics in local dev.
PUBLIC_POSTHOG_KEY=phc_xxx
