---
interface Props {
  id: string;
  eyebrow: string;
  title: string;
  description: string;
}

const { id, eyebrow, title, description } = Astro.props;
---

<article id={id} class="scroll-mt-28">
  <div class="grid lg:grid-cols-12 gap-x-8 gap-y-6 items-end mb-10 lg:mb-12">
    <div class="lg:col-span-7 animate-on-scroll">
      <div class="flex items-center gap-3 mb-4">
        <span class="h-px w-10 bg-gold-500"></span>
        <span class="text-[11px] font-semibold tracking-[0.22em] uppercase text-navy-700">
          {eyebrow}
        </span>
      </div>
      <h2
        class="font-heading text-[1.75rem] sm:text-[2.25rem] lg:text-[2.75rem] font-extrabold text-navy-900 leading-[1.1] tracking-tight"
      >
        {title}
      </h2>
    </div>
    <div
      class="lg:col-span-4 lg:col-start-9 lg:pb-2 animate-on-scroll"
      style="animation-delay: 140ms"
    >
      <p class="text-text-muted text-base leading-relaxed max-w-sm">
        {description}
      </p>
    </div>
  </div>

  <div class="relative animate-on-scroll">
    <span
      aria-hidden="true"
      class="hidden lg:block absolute -top-3 -left-3 w-6 h-6 border-t-2 border-l-2 border-gold-500"
    ></span>
    <span
      aria-hidden="true"
      class="hidden lg:block absolute -top-3 -right-3 w-6 h-6 border-t-2 border-r-2 border-gold-500"
    ></span>
    <span
      aria-hidden="true"
      class="hidden lg:block absolute -bottom-3 -left-3 w-6 h-6 border-b-2 border-l-2 border-gold-500"
    ></span>
    <span
      aria-hidden="true"
      class="hidden lg:block absolute -bottom-3 -right-3 w-6 h-6 border-b-2 border-r-2 border-gold-500"
    ></span>
    <slot />
  </div>
</article>
