---
import Button from "./ui/Button.astro";

const faqs = [
  {
    question: "Είναι το timologio.ai συμβατό με την ΑΑΔΕ;",
    answer: "Το timologio.ai στέλνει τιμολόγια απευθείας στο myDATA μέσω του επίσημου REST API και κάθε τιμολόγιο επικυρώνεται σε πραγματικό χρόνο. Η πιστοποίηση ως αδειοδοτημένος πάροχος ηλεκτρονικής τιμολόγησης είναι ξεχωριστή διαδικασία και θα ανακοινωθεί όταν ολοκληρωθεί.",
  },
  {
    question: "Ποιες γλώσσες κατανοεί ο AI βοηθός;",
    answer: "Ο AI βοηθός κατανοεί πλήρως τα ελληνικά (συμπεριλαμβανομένου του καθημερινού λόγου και των ιδιωματισμών) καθώς και τα αγγλικά. Η φωνητική εισαγωγή υποστηρίζεται στα ελληνικά με κατανόηση φυσικής γλώσσας.",
  },
  {
    question: "Μπορώ να μεταφέρω τα δεδομένα μου από άλλον πάροχο τιμολόγησης;",
    answer: "Ναι! Υποστηρίζουμε εισαγωγή CSV/Excel και μπορούμε να ανακτήσουμε το ιστορικό αποσταλμένων τιμολογίων σας απευθείας από το myDATA. Η ομάδα μας θα σας βοηθήσει να κάνετε τη μετάβαση απρόσκοπτα.",
  },
  {
    question: "Τι κερδίζω αν εγγραφώ ως πρώτος χρήστης;",
    answer: "Οι πρώτοι χρήστες έχουν δωρεάν πρόσβαση σε όλη τη διάρκεια της δοκιμαστικής περιόδου, επιπλέον 3 μήνες δωρεάν μετά την επίσημη κυκλοφορία, καθώς και απευθείας γραμμή επικοινωνίας με την ομάδα μας για κάθε ερώτηση ή βοήθεια.",
  },
  {
    question: "Υπάρχει εφαρμογή για κινητό;",
    answer: "Φυσικά. Το timologio.ai είναι διαθέσιμο ως πλήρης native εφαρμογή τόσο σε iOS όσο και σε Android, με τον ίδιο AI βοηθό, σάρωση αποδείξεων και analytics.",
  },
  {
    question: "Πόσο ασφαλή είναι τα δεδομένα μου;",
    answer: "Τα δεδομένα σας είναι κρυπτογραφημένα τόσο κατά την αποθήκευση όσο και κατά τη μεταφορά. Χρησιμοποιούμε Supabase (PostgreSQL) με row-level security, και όλη η επικοινωνία με την ΑΑΔΕ γίνεται μέσω TLS. Δεν μοιραζόμαστε ποτέ τα δεδομένα σας με τρίτους.",
  },
];
---

<section id="beta" class="relative py-20 lg:py-28 bg-navy-50/50 overflow-hidden">
  <!-- Subtle dotted texture -->
  <div
    class="absolute inset-0 opacity-50 pointer-events-none"
    style="background-image: radial-gradient(circle, oklch(0.72 0.03 260 / 0.18) 1px, transparent 1px); background-size: 26px 26px; mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Editorial header -->
    <div class="text-center max-w-2xl mx-auto mb-14 animate-on-scroll">
      <div class="inline-flex items-center gap-3 mb-5">
        <span class="h-px w-10 bg-gold-500"></span>
        <span class="text-[11px] font-semibold tracking-[0.22em] uppercase text-navy-700">Πριν την επίσημη κυκλοφορία</span>
        <span class="h-px w-10 bg-gold-500"></span>
      </div>
      <h2 class="font-heading text-3xl sm:text-4xl lg:text-[2.75rem] font-extrabold text-navy-900 leading-[1.1] tracking-tight mb-5">
        Γίνετε από τους <span class="relative inline-block">
          πρώτους
          <svg
            class="absolute -bottom-1.5 left-0 w-full h-[0.4em]"
            viewBox="0 0 200 12"
            fill="none"
            preserveAspectRatio="none"
            aria-hidden="true"
          >
            <path
              d="M4 8 Q 50 2, 100 7 T 196 6"
              stroke="oklch(0.78 0.12 75)"
              stroke-width="3"
              stroke-linecap="round"
              fill="none"
            ></path>
          </svg>
        </span> χρήστες του timologio.ai
      </h2>
      <p class="text-text-muted text-lg leading-relaxed">
        Δείτε τι κερδίζετε αν εγγραφείτε τώρα — πριν κυκλοφορήσει επίσημα η εφαρμογή.
      </p>
    </div>

    <!-- Split: narrative LEFT + signup form RIGHT -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-start">

      <!-- LEFT: Letter + numbered benefits -->
      <div class="animate-on-scroll" style="animation-delay: 80ms">

        <!-- Note from the team -->
        <div class="relative bg-surface-card border border-gold-500/40 rounded-[var(--radius-2xl)] p-6 sm:p-7 mb-10 shadow-sm">
          <div class="absolute -top-3 left-6 inline-flex items-center gap-1.5 bg-gold-500 text-navy-950 text-[10px] font-bold uppercase tracking-[0.18em] px-3 py-1 rounded-full shadow-sm">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M2 5.5A2.5 2.5 0 014.5 3h15A2.5 2.5 0 0122 5.5v13a2.5 2.5 0 01-2.5 2.5h-15A2.5 2.5 0 012 18.5v-13zM4 6.08V18.5a.5.5 0 00.5.5h15a.5.5 0 00.5-.5V6.08l-7.48 4.49a1 1 0 01-1.04 0L4 6.08z"/></svg>
            Από την ομάδα μας
          </div>
          <p class="italic text-navy-900/85 leading-[1.75] text-[15px] sm:text-base pt-1">
            «Χτίζουμε το timologio.ai για Έλληνες επιχειρηματίες και θέλουμε την ειλικρινή σας γνώμη πριν βγει επίσημα. Γι' αυτό, σε όσους μας εμπιστευτούν πρώτοι, προσφέρουμε τρία μοναδικά προνόμια — που δεν θα ξαναπροσφέρουμε ποτέ.»
          </p>
        </div>

        <!-- Numbered benefits list -->
        <ol class="space-y-8">
          <li class="flex gap-5 sm:gap-6">
            <span class="font-heading text-4xl sm:text-5xl font-extrabold text-gold-500 leading-[0.9] tabular-nums w-12 flex-shrink-0">01</span>
            <div class="min-w-0 flex-1 pt-1">
              <h3 class="text-lg sm:text-xl font-bold text-navy-900 mb-1.5 leading-tight">
                Δωρεάν πρόσβαση από σήμερα
              </h3>
              <p class="text-sm sm:text-[15px] text-text-muted leading-relaxed">
                Δοκιμάζετε ολόκληρη την εφαρμογή χωρίς να πληρώσετε τίποτα. Χωρίς πιστωτική κάρτα, χωρίς δέσμευση.
              </p>
            </div>
          </li>

          <li class="flex gap-5 sm:gap-6">
            <span class="font-heading text-4xl sm:text-5xl font-extrabold text-gold-500 leading-[0.9] tabular-nums w-12 flex-shrink-0">02</span>
            <div class="min-w-0 flex-1 pt-1">
              <h3 class="text-lg sm:text-xl font-bold text-navy-900 mb-1.5 leading-tight">
                3 μήνες δώρο μετά την επίσημη κυκλοφορία
              </h3>
              <p class="text-sm sm:text-[15px] text-text-muted leading-relaxed">
                Όταν βγει η τελική έκδοση, σας κερνάμε τους πρώτους 3 μήνες συνδρομής. Χωρίς καμία χρέωση.
              </p>
            </div>
          </li>

          <li class="flex gap-5 sm:gap-6">
            <span class="font-heading text-4xl sm:text-5xl font-extrabold text-gold-500 leading-[0.9] tabular-nums w-12 flex-shrink-0">03</span>
            <div class="min-w-0 flex-1 pt-1">
              <h3 class="text-lg sm:text-xl font-bold text-navy-900 mb-1.5 leading-tight">
                Απευθείας γραμμή με την ομάδα μας
              </h3>
              <p class="text-sm sm:text-[15px] text-text-muted leading-relaxed">
                Για κάθε ερώτηση ή βοήθεια, μιλάτε απευθείας μαζί μας. Γρήγορες απαντήσεις από πραγματικούς ανθρώπους — όχι αυτόματα μηνύματα.
              </p>
            </div>
          </li>
        </ol>
      </div>

      <!-- RIGHT: Signup form -->
      <div class="animate-on-scroll" style="animation-delay: 140ms">

        <!-- Live signup counter above the form -->
        <div class="flex items-center gap-2.5 mb-4 px-1">
          <span class="relative flex h-2.5 w-2.5 flex-shrink-0" aria-hidden="true">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-success"></span>
          </span>
          <p class="text-sm text-text-muted">
            <span class="tabular-nums font-bold text-navy-900" data-beta-counter>—</span>
            επιχειρήσεις έχουν ήδη εγγραφεί
          </p>
        </div>

        <!-- Form card -->
        <div class="relative bg-surface-card rounded-[var(--radius-2xl)] border border-border p-7 sm:p-8 shadow-xl">
          <div class="absolute -top-3 left-7 inline-flex items-center gap-1.5 bg-navy-900 text-white text-[10px] font-semibold uppercase tracking-[0.18em] px-3 py-1 rounded-full shadow-sm">
            <svg class="w-3 h-3 text-gold-500" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            Εγγραφή · 30 δευτερόλεπτα
          </div>

          <h3 class="text-xl sm:text-2xl font-extrabold text-navy-900 mt-2 mb-2 leading-tight">
            Κλειδώστε τα προνόμιά σας
          </h3>
          <p class="text-sm text-text-muted mb-6 leading-relaxed">
            Συμπληρώστε τα στοιχεία σας και θα σας στείλουμε πρόσβαση στην εφαρμογή μέσα σε 24 ώρες.
          </p>

          <form id="beta-form" class="text-left" novalidate>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <input
                type="text"
                name="name"
                placeholder="Ονοματεπώνυμο"
                class="px-4 py-3 rounded-[var(--radius-lg)] border border-border bg-white text-sm text-navy-900 placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500"
                required
              />
              <input
                type="email"
                name="email"
                placeholder="your@email.com"
                class="px-4 py-3 rounded-[var(--radius-lg)] border border-border bg-white text-sm text-navy-900 placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500"
                required
              />
              <select
                name="business_type"
                class="pl-4 pr-10 py-3 rounded-[var(--radius-lg)] border border-border bg-white text-sm text-navy-900 focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500"
                required
              >
                <option value="" disabled selected>Τύπος επιχείρησης</option>
                <option value="Ελεύθερος επαγγελματίας">Ελεύθερος επαγγελματίας</option>
                <option value="Ατομική επιχείρηση">Ατομική επιχείρηση</option>
                <option value="Μικρή εταιρεία">Μικρή εταιρεία</option>
              </select>
              <select
                name="current_tool"
                class="pl-4 pr-10 py-3 rounded-[var(--radius-lg)] border border-border bg-white text-sm text-navy-900 focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500"
                required
              >
                <option value="" disabled selected>Τρέχον πάροχος</option>
                <option value="Epsilonnet">Epsilonnet</option>
                <option value="SoftOne">SoftOne</option>
                <option value="Elorus">Elorus</option>
                <option value="Eurofast">Eurofast</option>
                <option value="Κανένα/Χειρόγραφα">Κανένα / Χειρόγραφα</option>
                <option value="Άλλο">Άλλο</option>
              </select>
            </div>

            <div id="beta-other-wrap" class="mt-3 hidden">
              <input
                type="text"
                name="current_tool_other"
                placeholder="Ποιο εργαλείο;"
                class="w-full px-4 py-3 rounded-[var(--radius-lg)] border border-border bg-white text-sm text-navy-900 placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-gold-500/30 focus:border-gold-500"
              />
            </div>

            <label class="mt-4 flex items-start gap-2.5 text-sm text-text-muted leading-relaxed cursor-pointer">
              <input
                type="checkbox"
                name="consent_privacy"
                class="mt-0.5 h-4 w-4 rounded border-border text-gold-600 focus:ring-2 focus:ring-gold-500/30 accent-gold-500 flex-shrink-0"
                required
              />
              <span>
                Αποδέχομαι την <a href="/privacy" class="text-gold-600 hover:text-gold-700 underline">Πολιτική Απορρήτου</a> και συναινώ στην επεξεργασία των στοιχείων μου για επικοινωνία σχετικά με τη δοκιμαστική περίοδο.
              </span>
            </label>

            <div class="mt-5">
              <Button variant="gold" size="lg" class="w-full">
                <span data-beta-submit-label>Κλειδώστε τη θέση σας</span>
                <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </Button>
            </div>

            <p id="beta-error" class="hidden mt-3 text-sm text-red-600 text-center"></p>
          </form>

          <div id="beta-success" class="hidden">
            <div class="rounded-[var(--radius-xl)] border border-gold-500/40 bg-gold-500/10 p-6 text-center">
              <div class="text-2xl mb-2">🎉</div>
              <p class="text-lg font-bold text-navy-900 mb-1">Είστε στη λίστα!</p>
              <p class="text-sm text-text-muted mb-3">
                Θέση <span class="font-semibold text-gold-600" data-beta-position>#—</span> στη λίστα αναμονής.
              </p>
              <p class="text-sm text-text-muted">
                Θα επικοινωνήσουμε σύντομα για να ξεκινήσετε τη δοκιμή και να κλειδώσουμε τα προνόμιά σας.
              </p>
            </div>
          </div>

          <!-- Trust microline -->
          <div class="flex items-center justify-center gap-4 mt-5 text-xs text-text-muted">
            <div class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-success" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Χωρίς πιστωτική κάρτα
            </div>
            <span class="text-border">·</span>
            <div class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-success" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Ακύρωση οποτεδήποτε
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ Accordion -->
    <div class="mt-24 max-w-3xl mx-auto animate-on-scroll">
      <h3 class="text-xl font-bold text-navy-900 text-center mb-8">Συχνές Ερωτήσεις</h3>
      <div class="space-y-2">
        {faqs.map((faq) => (
          <details class="group bg-surface-card rounded-[var(--radius-lg)] border border-border overflow-hidden">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none text-sm font-medium text-navy-900 hover:bg-navy-50/50 transition-colors">
              {faq.question}
              <svg class="w-4 h-4 text-text-muted flex-shrink-0 ml-4 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pb-4 text-sm text-text-muted leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:5000";

  // ---- Social proof counter (deterministic, grows daily) ----
  const counterEl = document.querySelector<HTMLElement>("[data-beta-counter]");
  let counterTarget = 36;
  if (counterEl) {
    const START_DATE = new Date("2026-03-24T00:00:00Z").getTime();
    const BASE = 15;
    const daysSince = Math.max(0, Math.floor((Date.now() - START_DATE) / 86_400_000));
    counterTarget = BASE + daysSince;

    const animateTo = (target: number, fromZero = false) => {
      const startVal = fromZero ? 0 : parseInt(counterEl.textContent || "0", 10) || 0;
      const duration = fromZero ? 1400 : 600;
      const startTime = performance.now();
      const step = (t: number) => {
        const elapsed = t - startTime;
        const progress = Math.min(1, elapsed / duration);
        const eased = 1 - Math.pow(1 - progress, 3);
        const value = Math.round(startVal + (target - startVal) * eased);
        counterEl.textContent = value.toString();
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animateTo(counterTarget, true);
            io.disconnect();
          }
        });
      },
      { threshold: 0.35 }
    );
    io.observe(counterEl);

    // Expose for the form submit handler to bump on signup
    (window as unknown as { __bumpBetaCounter?: () => void }).__bumpBetaCounter = () => {
      counterTarget += 1;
      animateTo(counterTarget, false);
    };
  }

  // ---- Signup form ----
  const form = document.getElementById("beta-form") as HTMLFormElement | null;
  const successBlock = document.getElementById("beta-success");
  const errorEl = document.getElementById("beta-error");
  const otherWrap = document.getElementById("beta-other-wrap");
  const submitLabel = document.querySelector("[data-beta-submit-label]");
  const positionEl = document.querySelector("[data-beta-position]");

  if (form && successBlock && errorEl && otherWrap && submitLabel && positionEl) {
    const toolSelect = form.querySelector<HTMLSelectElement>('select[name="current_tool"]');
    const otherInput = form.querySelector<HTMLInputElement>('input[name="current_tool_other"]');
    const submitBtn = form.querySelector<HTMLButtonElement>("button");

    toolSelect?.addEventListener("change", () => {
      const showOther = toolSelect.value === "Άλλο";
      otherWrap.classList.toggle("hidden", !showOther);
      if (otherInput) otherInput.required = showOther;
      if (!showOther && otherInput) otherInput.value = "";
    });

    const showError = (msg: string) => {
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    };
    const hideError = () => {
      errorEl.textContent = "";
      errorEl.classList.add("hidden");
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      hideError();

      const data = new FormData(form);
      const payload: Record<string, string | boolean> = {
        name: (data.get("name") as string || "").trim(),
        email: (data.get("email") as string || "").trim(),
        business_type: (data.get("business_type") as string) || "",
        current_tool: (data.get("current_tool") as string) || "",
      };
      const other = (data.get("current_tool_other") as string || "").trim();
      if (payload.current_tool === "Άλλο" && other) {
        payload.current_tool_other = other;
      }
      const consentGiven = data.get("consent_privacy") !== null;

      if (!payload.name || !payload.email || !payload.business_type || !payload.current_tool) {
        showError("Παρακαλώ συμπληρώστε όλα τα πεδία.");
        return;
      }
      if (payload.current_tool === "Άλλο" && !other) {
        showError("Παρακαλώ συμπληρώστε το πεδίο 'Άλλο εργαλείο'.");
        return;
      }
      if (!consentGiven) {
        showError("Παρακαλώ αποδεχτείτε την Πολιτική Απορρήτου για να συνεχίσετε.");
        return;
      }
      payload.consent_privacy = true;

      if (submitBtn) submitBtn.disabled = true;
      const originalLabel = submitLabel.textContent;
      submitLabel.textContent = "Εγγραφή...";

      try {
        const res = await fetch(`${API_URL}/api/waitlist`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        const json = await res.json().catch(() => ({}));

        if (res.ok && typeof json.position === "number") {
          positionEl.textContent = `#${json.position}`;
          form.classList.add("hidden");
          successBlock.classList.remove("hidden");
          (window as unknown as { __bumpBetaCounter?: () => void }).__bumpBetaCounter?.();
          return;
        }
        showError(json.error || "Σφάλμα εγγραφής. Δοκιμάστε ξανά.");
      } catch {
        showError("Σφάλμα σύνδεσης. Δοκιμάστε ξανά.");
      } finally {
        if (submitBtn) submitBtn.disabled = false;
        submitLabel.textContent = originalLabel;
      }
    });
  }
</script>
