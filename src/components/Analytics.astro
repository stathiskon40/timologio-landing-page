---
const kpis = [
  { label: "Έσοδα", value: "€47,250", color: "oklch(0.78 0.12 75)" },
  { label: "Έξοδα", value: "€18,430", color: "oklch(0.45 0.10 260)" },
  { label: "Καθαρό Κέρδος", value: "€28,820", color: "oklch(0.65 0.10 150)" },
  { label: "Υπόλοιπο ΦΠΑ", value: "€6,912", color: "oklch(0.55 0.08 200)" },
];

// Monthly revenue vs expenses (simplified)
const months = ["Ιαν", "Φεβ", "Μαρ", "Απρ", "Μαϊ", "Ιουν"];
const revenue = [6200, 7100, 8400, 7800, 9200, 8550];
const expenses = [2800, 3100, 2600, 3400, 3200, 3330];
const maxVal = 10000;
const barWidth = 28;
const gap = 12;
const groupWidth = barWidth * 2 + gap;
const chartWidth = months.length * groupWidth + (months.length - 1) * 24;
const chartHeight = 160;
---

<section id="analytics" class="py-20 lg:py-28 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div class="animate-on-scroll">
        <p class="text-sm font-semibold text-gold-500 uppercase tracking-wider mb-3">Analytics</p>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-navy-900 mb-6">
          Τα οικονομικά σας, ξεκάθαρα
        </h2>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-gold-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <div>
              <p class="font-semibold text-navy-900">Παρακολούθηση εσόδων & εξόδων σε πραγματικό χρόνο</p>
              <p class="text-sm text-text-muted">Δείτε ακριβώς πού πηγαίνουν τα χρήματά σας με αυτόματη κατηγοριοποίηση.</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-gold-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
            <div>
              <p class="font-semibold text-navy-900">Ισοζύγιο ΦΠΑ πάντα ορατό</p>
              <p class="text-sm text-text-muted">Εισπραχθείς έναντι καταβληθέντος ΦΠΑ, για αβίαστες τριμηνιαίες υποβολές.</p>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-gold-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <p class="font-semibold text-navy-900">Ανάλυση περιθωρίων κέρδους</p>
              <p class="text-sm text-text-muted">Η Τεχνητή Νοημοσύνη αναδεικνύει τάσεις, εποχικότητα και ευκαιρίες.</p>
            </div>
          </li>
        </ul>
      </div>

      <!-- Right: Dashboard mockup -->
      <div class="animate-on-scroll slide-right">
        <!-- Browser chrome -->
        <div class="bg-surface-card rounded-[var(--radius-xl)] border border-border shadow-lg overflow-hidden">
          <div class="flex items-center gap-1.5 px-4 py-2.5 bg-navy-50 border-b border-border">
            <div class="w-2.5 h-2.5 rounded-full bg-red-400/50"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/50"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-green-400/50"></div>
            <div class="ml-3 flex-1 bg-white rounded-md px-3 py-1 text-[10px] text-text-muted border border-border">
              app.timologio.ai/dashboard
            </div>
          </div>

          <div class="p-4 space-y-4">
            <!-- KPI Cards -->
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
              {kpis.map((kpi) => (
                <div class="rounded-[var(--radius-lg)] border border-border p-3" style={`border-left: 2px solid ${kpi.color}`}>
                  <p class="text-[10px] uppercase tracking-wide text-text-muted">{kpi.label}</p>
                  <p class="text-base font-bold text-navy-900 mt-0.5 tabular-nums">{kpi.value}</p>
                  <p class="text-[9px] uppercase tracking-wide text-text-muted mt-0.5">6μηνο</p>
                </div>
              ))}
            </div>

            <!-- Bar Chart -->
            <div class="rounded-[var(--radius-lg)] border border-border p-4">
              <div class="flex items-baseline justify-between mb-3">
                <p class="text-xs font-semibold text-navy-900">Έσοδα vs Έξοδα</p>
                <p class="text-[9px] uppercase tracking-wide text-text-muted">Μηνιαία (€)</p>
              </div>
              <svg viewBox={`0 0 ${chartWidth + 40} ${chartHeight + 30}`} class="w-full">
                {months.map((month, i) => {
                  const x = 30 + i * (groupWidth + 24);
                  const revH = (revenue[i] / maxVal) * chartHeight;
                  const expH = (expenses[i] / maxVal) * chartHeight;
                  return (
                    <g>
                      <rect
                        x={x}
                        y={chartHeight - revH}
                        width={barWidth}
                        height={revH}
                        rx="3"
                        fill="oklch(0.78 0.12 75)"
                        opacity="0.85"
                      />
                      <rect
                        x={x + barWidth + gap}
                        y={chartHeight - expH}
                        width={barWidth}
                        height={expH}
                        rx="3"
                        fill="oklch(0.45 0.10 260)"
                        opacity="0.6"
                      />
                      <text
                        x={x + groupWidth / 2}
                        y={chartHeight + 18}
                        text-anchor="middle"
                        fill="oklch(0.50 0.02 260)"
                        font-size="10"
                        font-family="Inter, system-ui"
                      >
                        {month}
                      </text>
                    </g>
                  );
                })}
                {/* Y-axis labels */}
                {[0, 2500, 5000, 7500, 10000].map((v) => {
                  const y = chartHeight - (v / maxVal) * chartHeight;
                  return (
                    <g>
                      <text x="25" y={y + 3} text-anchor="end" fill="oklch(0.50 0.02 260)" font-size="9" font-family="Inter, system-ui">
                        {v / 1000}k
                      </text>
                      <line x1="30" y1={y} x2={chartWidth + 30} y2={y} stroke="oklch(0.905 0.008 260)" stroke-width="0.5" />
                    </g>
                  );
                })}
              </svg>
              <!-- Legend -->
              <div class="flex items-center gap-4 mt-2">
                <div class="flex items-center gap-1.5">
                  <div class="w-3 h-3 rounded-sm" style="background: oklch(0.78 0.12 75)"></div>
                  <span class="text-[10px] text-text-muted">Έσοδα</span>
                </div>
                <div class="flex items-center gap-1.5">
                  <div class="w-3 h-3 rounded-sm" style="background: oklch(0.45 0.10 260)"></div>
                  <span class="text-[10px] text-text-muted">Έξοδα</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
