---
import Button from "./ui/Button.astro";
import Badge from "./ui/Badge.astro";
---

<section data-nav-theme="dark" class="relative bg-navy-900 overflow-hidden pt-24 pb-16 lg:pt-32 lg:pb-24">
  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: url('data:image/svg+xml,%3Csvg width=%2260%22 height=%2260%22 viewBox=%220 0 60 60%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cpath d=%22M0 0h60v60H0z%22/%3E%3Cpath d=%22M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z%22 fill=%22%23ffffff%22/%3E%3C/g%3E%3C/svg%3E')"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div class="text-center lg:text-left">
        <Badge variant="gold" class="mb-6">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Φτιαγμένο για Έλληνες επαγγελματίες
        </Badge>

        <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold text-white leading-[1.1] tracking-tight mb-6">
          Υπαγορεύετε το τιμολόγιο.<br />
          <span class="text-gold-500">Φεύγει στο myDATA σε 30&nbsp;δευτερόλεπτα.</span>
        </h1>

        <p class="text-lg text-navy-300 max-w-xl mx-auto lg:mx-0 mb-8 leading-relaxed">
          Το γράφετε ή το υπαγορεύετε στα ελληνικά. Ο βοηθός συμπληρώνει τα στοιχεία, εσείς επιβεβαιώνετε, η ΑΑΔΕ το παραλαμβάνει. Η ίδια εφαρμογή καταχωρεί αποδείξεις από φωτογραφία και κρατά ΦΠΑ, ΕΦΚΑ και τεκμήρια πάντα ενημερωμένα.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start mb-6">
          <Button variant="gold" size="lg" href="#beta">
            Δοκιμάστε δωρεάν
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </Button>
          <Button variant="outline" size="lg" href="#demo">
            Δείτε το σε 2 λεπτά
          </Button>
        </div>

        <!-- Compliance trust microline -->
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 justify-center lg:justify-start text-[11px] font-semibold tracking-[0.18em] uppercase text-navy-400 mb-5">
          <span class="flex items-center gap-1.5">
            <svg class="w-3 h-3 text-gold-500" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"/></svg>
            ΑΑΔΕ-συμβατό
          </span>
          <span class="text-navy-600">·</span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3 h-3 text-gold-500" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"/></svg>
            IRIS έτοιμο
          </span>
          <span class="text-navy-600">·</span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3 h-3 text-gold-500" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"/></svg>
            B2B 2026-ready
          </span>
        </div>

        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 justify-center lg:justify-start text-sm text-navy-400">
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-gold-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Χωρίς πιστωτική κάρτα
          </div>
          <span class="text-navy-600">|</span>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-gold-500" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Συμβατό με myDATA
          </div>
          <span class="text-navy-600">|</span>
          <a href="#beta" class="group flex items-center gap-1.5 hover:text-white transition-colors">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-success"></span>
            </span>
            <span class="tabular-nums font-semibold text-white/80" data-hero-counter>...</span>
            <span>επιχειρήσεις έχουν ήδη εγγραφεί</span>
          </a>
        </div>
      </div>

      <!-- Right: Chat mockup -->
      <div class="relative animate-on-scroll slide-right">
        <div class="bg-navy-800/60 rounded-[var(--radius-2xl)] border border-white/10 p-1 shadow-2xl backdrop-blur-sm">
          <!-- Window chrome -->
          <div class="flex items-center gap-1.5 px-4 py-3 border-b border-white/5">
            <div class="w-2.5 h-2.5 rounded-full bg-white/15"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-white/15"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-white/15"></div>
            <span class="ml-3 text-xs text-white/30 font-medium">katastixo.com</span>
          </div>

          <!-- Chat area -->
          <div class="p-4 space-y-4 min-h-[320px]">
            <!-- AI greeting -->
            <div class="flex items-start gap-3">
              <div class="w-7 h-7 rounded-full bg-gold-500/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-gold-500" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <div class="bg-white/5 rounded-[var(--radius-lg)] rounded-tl-sm px-4 py-3 max-w-[85%]">
                <p class="text-sm text-white/80">Καλησπέρα σας. Τι τιμολόγιο να ετοιμάσουμε;</p>
              </div>
            </div>

            <!-- User message -->
            <div class="flex justify-end">
              <div class="bg-gold-500/15 rounded-[var(--radius-lg)] rounded-tr-sm px-4 py-3 max-w-[85%]">
                <p class="text-sm text-white/90">Τιμολόγιο 500€ στον Παπαδόπουλο για συμβουλευτικές υπηρεσίες</p>
              </div>
            </div>

            <!-- AI response with invoice preview -->
            <div class="flex items-start gap-3">
              <div class="w-7 h-7 rounded-full bg-gold-500/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-gold-500" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
              </div>
              <div class="space-y-2 max-w-[85%]">
                <div class="bg-white/5 rounded-[var(--radius-lg)] rounded-tl-sm px-4 py-3">
                  <p class="text-sm text-white/80">Ετοιμάστηκε. Δείτε το:</p>
                </div>

                <!-- Invoice card -->
                <div class="bg-white/[0.08] rounded-[var(--radius-lg)] border border-white/10 p-4">
                  <div class="flex items-center justify-between mb-3">
                    <span class="text-xs font-semibold text-gold-500 uppercase tracking-wider">Τιμολόγιο Παροχής Υπηρεσιών</span>
                    <span class="text-[10px] px-2 py-0.5 bg-gold-500/20 text-gold-400 rounded-full font-medium">Προσχέδιο</span>
                  </div>
                  <div class="space-y-2 text-xs text-white/60">
                    <div class="flex justify-between">
                      <span>Πελάτης</span>
                      <span class="text-white/80">Παπαδόπουλος ΑΕ</span>
                    </div>
                    <div class="flex justify-between">
                      <span>Περιγραφή</span>
                      <span class="text-white/80">Υπηρεσίες Συμβούλου</span>
                    </div>
                    <div class="border-t border-white/5 my-1"></div>
                    <div class="flex justify-between">
                      <span>Καθαρή αξία</span>
                      <span class="text-white/80">500,00 €</span>
                    </div>
                    <div class="flex justify-between">
                      <span>ΦΠΑ 24%</span>
                      <span class="text-white/80">120,00 €</span>
                    </div>
                    <div class="flex justify-between font-semibold text-white pt-1 border-t border-white/10">
                      <span>Σύνολο</span>
                      <span>620,00 €</span>
                    </div>
                  </div>
                  <div class="mt-3 flex gap-2">
                    <button class="flex-1 text-xs bg-gold-500 text-navy-950 font-semibold py-1.5 rounded-[var(--radius-base)] hover:bg-gold-400 transition-colors">
                      Αποστολή στο myDATA
                    </button>
                    <button class="text-xs text-white/50 hover:text-white/70 px-3 py-1.5 border border-white/10 rounded-[var(--radius-base)] transition-colors">
                      Επεξεργασία
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Decorative glow -->
        <div class="absolute -inset-4 bg-gold-500/5 rounded-[2rem] blur-3xl -z-10"></div>
      </div>
    </div>
  </div>

  <!-- Bottom wave -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 48" fill="none" class="w-full text-surface">
      <path d="M0 48h1440V24C1200 0 960 48 720 24S240 48 0 24v24z" fill="currentColor"/>
    </svg>
  </div>
</section>

<script>
  // Hero social-proof counter — mirrors the Beta section formula
  const heroCounter = document.querySelector<HTMLElement>("[data-hero-counter]");
  if (heroCounter) {
    const START_DATE = new Date("2026-03-24T00:00:00Z").getTime();
    const BASE = 15;
    const daysSince = Math.max(0, Math.floor((Date.now() - START_DATE) / 86_400_000));
    const target = BASE + daysSince;

    const duration = 1600;
    const startTime = performance.now();
    const step = (t: number) => {
      const progress = Math.min(1, (t - startTime) / duration);
      const eased = 1 - Math.pow(1 - progress, 3);
      heroCounter.textContent = Math.round(eased * target).toString();
      if (progress < 1) requestAnimationFrame(step);
    };
    // Small delay so the hero animation doesn't start while page is still laying out
    setTimeout(() => requestAnimationFrame(step), 400);
  }
</script>
