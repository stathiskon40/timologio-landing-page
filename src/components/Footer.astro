---
const productLinks = [
  { label: "Δυνατότητες", href: "/#features" },
  { label: "Πώς λειτουργεί", href: "/#demo" },
  { label: "Στατιστικά", href: "/#analytics" },
  { label: "Τιμές", href: "/#pricing" },
  { label: "Προνόμια", href: "/#beta" },
];

const legalLinks = [
  { label: "Πολιτική Απορρήτου", href: "/privacy" },
  { label: "Όροι Χρήσης", href: "/terms" },
  { label: "Πολιτική Cookies", href: "/cookies" },
];
---

<footer data-nav-theme="dark" class="bg-navy-900 text-white pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10 mb-12">
      <!-- Logo + tagline -->
      <div>
        <a href="#" class="flex items-center gap-2 mb-4">
          <img src="/logos/only_logo.svg" alt="" width="36" height="36" class="w-9 h-9" />
          <span class="font-heading font-bold text-lg text-white">
            kiros<span class="text-gold-500">.gr</span>
          </span>
        </a>
        <p class="text-sm text-navy-400 leading-relaxed mb-6">
          Ηλεκτρονική τιμολόγηση σχεδιασμένη για Έλληνες επαγγελματίες. Συμβατή με το myDATA της ΑΑΔΕ από την πρώτη μέρα.
        </p>
        <div class="inline-flex items-center gap-1.5 text-xs text-navy-400 border border-navy-700 rounded-full px-3 py-1.5">
          <svg class="w-[18px] h-3 rounded-[1px] overflow-hidden" viewBox="0 0 27 18" fill="none" aria-label="Greek flag">
            <rect width="27" height="18" fill="#0d5eaf"/>
            <rect x="10" y="2" width="17" height="2" fill="#ffffff"/>
            <rect x="10" y="6" width="17" height="2" fill="#ffffff"/>
            <rect y="10" width="27" height="2" fill="#ffffff"/>
            <rect y="14" width="27" height="2" fill="#ffffff"/>
            <rect y="4" width="10" height="2" fill="#ffffff"/>
            <rect x="4" width="2" height="10" fill="#ffffff"/>
          </svg>
          Φτιαγμένο στην Ελλάδα
        </div>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4">Προϊόν</h4>
        <ul class="space-y-2.5">
          {productLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-navy-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4">Νομικά</h4>
        <ul class="space-y-2.5">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-navy-400 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href="mailto:contact@kiros.gr" class="text-sm text-navy-400 hover:text-white transition-colors">
              Επικοινωνία
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider + Copyright -->
    <div class="border-t border-navy-800 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-navy-500">
        &copy; {new Date().getFullYear()} kiros.gr. Με επιφύλαξη παντός δικαιώματος.
      </p>
    </div>
  </div>
</footer>
