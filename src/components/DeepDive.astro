---
import Badge from "./ui/Badge.astro";

const features = [
  {
    tag: "Ταμειακή Ροή",
    title: "Δεν μένετε ποτέ άδειοι τον Ιούνιο",
    description:
      "Υπολογίζουμε αυτόματα πόσα χρωστάτε σε ΦΠΑ, ΕΦΚΑ και προκαταβολή φόρου — και κρατάμε εικονικά το ποσό στην άκρη με κάθε εξοφλημένο τιμολόγιο. Βλέπετε πάντα τι σας μένει πραγματικά.",
    visual: "cashflow",
    reversed: false,
  },
  {
    tag: "Πελάτες & Πληρωμές",
    title: "Οι πελάτες σας, οργανωμένοι",
    description:
      "Αυτόματη αναζήτηση ΑΦΜ μέσω ΑΑΔΕ και VIES, ιστορικό κινήσεων και πολυεπίπεδες υπενθυμίσεις σε μέιλ και Viber — μέχρι να εξοφληθεί το τιμολόγιο.",
    visual: "customers",
    reversed: true,
  },
  {
    tag: "Επαναλαμβανόμενα",
    title: "Μηνιαίοι πελάτες, μηδέν δουλειά",
    description:
      "Ρυθμίστε το μία φορά και τα τιμολόγια φεύγουν μόνα τους στον σωστό πελάτη κάθε μήνα — με αυτόματη χρέωση και αποστολή στο myDATA.",
    visual: "recurring",
    reversed: false,
  },
];
---

<section class="py-20 lg:py-28 bg-navy-50/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-20 lg:space-y-28">
    {features.map((feature, index) => (
      <div class:list={[
        "grid lg:grid-cols-2 gap-12 lg:gap-16 items-center",
        feature.reversed && "lg:[direction:rtl]",
      ]}>
        <!-- Copy -->
        <div class:list={["animate-on-scroll", feature.reversed && "lg:[direction:ltr]"]}>
          <Badge variant="gold" class="mb-4">{feature.tag}</Badge>
          <h3 class="text-2xl sm:text-3xl font-extrabold text-navy-900 mb-4">{feature.title}</h3>
          <p class="text-text-muted text-lg leading-relaxed">{feature.description}</p>
        </div>

        <!-- Visual -->
        <div class:list={[
          "animate-on-scroll lg:[direction:ltr]",
          feature.reversed ? "slide-left" : "slide-right",
        ]}>
          {feature.visual === "cashflow" && (
            <div class="bg-surface-card rounded-[var(--radius-xl)] border border-border p-5 shadow-sm">
              <div class="flex items-center justify-between mb-4">
                <p class="text-xs font-semibold text-navy-900">Αυτόν τον μήνα</p>
                <span class="text-[10px] font-semibold tracking-[0.18em] uppercase text-text-muted">Ιούνιος</span>
              </div>

              <div class="mb-5">
                <p class="text-[11px] uppercase tracking-[0.14em] text-text-muted mb-1">Εισπράχθηκαν</p>
                <p class="text-2xl font-heading font-extrabold text-navy-900 tabular-nums leading-none">€4.820<span class="text-sm text-text-muted font-semibold">,00</span></p>
              </div>

              <div class="space-y-3">
                {[
                  { label: "ΦΠΑ", amount: "€891", pct: 48, color: "oklch(0.78 0.12 75)" },
                  { label: "Προκαταβολή", amount: "€540", pct: 29, color: "oklch(0.65 0.10 260)" },
                  { label: "ΕΦΚΑ", amount: "€236", pct: 13, color: "oklch(0.55 0.08 260)" },
                ].map((row) => (
                  <div>
                    <div class="flex items-center justify-between mb-1 text-xs">
                      <span class="text-navy-700 font-medium">{row.label}</span>
                      <span class="tabular-nums text-text-muted">{row.amount}</span>
                    </div>
                    <div class="h-1.5 w-full bg-navy-100 rounded-full overflow-hidden">
                      <div class="h-full rounded-full" style={`width: ${row.pct}%; background-color: ${row.color};`}></div>
                    </div>
                  </div>
                ))}
              </div>

              <div class="mt-5 pt-4 border-t border-border flex items-center justify-between">
                <span class="text-xs text-text-muted">Σας μένουν</span>
                <span class="text-lg font-heading font-extrabold text-success tabular-nums">€3.153</span>
              </div>
            </div>
          )}

          {feature.visual === "customers" && (
            <div class="bg-surface-card rounded-[var(--radius-xl)] border border-border p-5 shadow-sm">
              <div class="flex items-start gap-4 mb-4">
                <div class="w-12 h-12 rounded-full bg-navy-100 flex items-center justify-center">
                  <span class="text-sm font-bold text-navy-700">ΜΝ</span>
                </div>
                <div>
                  <p class="font-semibold text-navy-900">Μαρία Νικολάου</p>
                  <p class="text-xs text-text-muted">Γραφιστικές Υπηρεσίες</p>
                </div>
              </div>
              <div class="grid grid-cols-2 gap-3 text-xs">
                <div class="bg-navy-50 rounded-[var(--radius-base)] p-2.5">
                  <span class="text-text-muted">ΑΦΜ</span>
                  <p class="font-medium text-navy-900 mt-0.5">123456789</p>
                </div>
                <div class="bg-navy-50 rounded-[var(--radius-base)] p-2.5">
                  <span class="text-text-muted">ΔΟΥ</span>
                  <p class="font-medium text-navy-900 mt-0.5">Α' Αθηνών</p>
                </div>
                <div class="bg-navy-50 rounded-[var(--radius-base)] p-2.5">
                  <span class="text-text-muted">Τιμολόγια</span>
                  <p class="font-medium text-navy-900 mt-0.5">12</p>
                </div>
                <div class="bg-navy-50 rounded-[var(--radius-base)] p-2.5">
                  <span class="text-text-muted">Σύνολο</span>
                  <p class="font-medium text-navy-900 mt-0.5">€8,640</p>
                </div>
              </div>
              <div class="mt-3 flex items-center gap-1.5 text-[10px] text-text-muted">
                <svg class="w-3 h-3 text-success" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Επαληθευμένο μέσω ΑΑΔΕ και VIES
              </div>
            </div>
          )}

          {feature.visual === "recurring" && (
            <div class="bg-surface-card rounded-[var(--radius-xl)] border border-border p-5 shadow-sm">
              <div class="flex items-center justify-between mb-4">
                <p class="text-xs font-semibold text-navy-900">Προγραμματισμένα</p>
                <span class="inline-flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-wider text-success">
                  <span class="relative flex h-1.5 w-1.5">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-success"></span>
                  </span>
                  Ενεργά
                </span>
              </div>

              <div class="space-y-2.5">
                {[
                  { client: "Αθανασίου ΕΠΕ", desc: "Συντήρηση ιστοσελίδας", amount: "€180", date: "1 κάθε μήνα" },
                  { client: "Παπαδοπούλου ΙΚΕ", desc: "Λογιστικές υπηρεσίες", amount: "€420", date: "5 κάθε μήνα" },
                  { client: "Greek Hosting AE", desc: "Hosting plan", amount: "€35", date: "15 κάθε μήνα" },
                ].map((r) => (
                  <div class="flex items-center justify-between py-2.5 px-3 rounded-[var(--radius-base)] bg-navy-50 border border-transparent hover:border-gold-300/60 transition-colors">
                    <div class="min-w-0">
                      <p class="text-sm font-medium text-navy-900 truncate">{r.client}</p>
                      <p class="text-[11px] text-text-muted truncate">{r.desc} · {r.date}</p>
                    </div>
                    <span class="text-sm font-semibold text-navy-900 tabular-nums ml-3">{r.amount}</span>
                  </div>
                ))}
              </div>

              <div class="mt-4 pt-3 border-t border-border flex items-center justify-between text-xs">
                <span class="text-text-muted">Επόμενη αποστολή</span>
                <span class="font-semibold text-navy-900">αύριο · 09:00</span>
              </div>
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</section>
