---
interface Props {
  variant?: "gold" | "navy" | "success" | "danger";
  class?: string;
}

const { variant = "gold", class: className = "" } = Astro.props;

const variants: Record<string, string> = {
  gold: "bg-gold-500/15 text-gold-500 border border-gold-500/25",
  navy: "bg-navy-700/10 text-navy-700 border border-navy-700/15",
  success: "bg-success/10 text-success border border-success/20",
  danger: "bg-danger/10 text-danger border border-danger/20",
};

const classes = [
  "inline-flex items-center gap-1.5 px-3 py-1 text-xs font-medium rounded-[var(--radius-full)]",
  variants[variant],
  className,
].join(" ");
---

<span class={classes}>
  <slot />
</span>
