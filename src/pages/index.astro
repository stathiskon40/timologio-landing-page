---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import LogoCloud from "../components/LogoCloud.astro";
import Features from "../components/Features.astro";
import ChatDemo from "../components/ChatDemo";
import Analytics from "../components/Analytics.astro";
import Compliance2026 from "../components/Compliance2026.astro";
import DeepDive from "../components/DeepDive.astro";
import PocketAccountant from "../components/PocketAccountant.astro";
import Comparison from "../components/Comparison.astro";
import Pricing from "../components/Pricing.astro";
import Beta from "../components/Beta.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <LogoCloud />
    <Features />

    <!-- AI Demo Section — editorial treatment matching Features -->
    <section id="demo" class="relative py-24 lg:py-32 bg-navy-50/60 overflow-hidden">
      <!-- Dotted grid texture + gold hairline divider -->
      <div
        class="absolute inset-0 opacity-60 pointer-events-none"
        style="background-image: radial-gradient(circle, oklch(0.72 0.03 260 / 0.25) 1px, transparent 1px); background-size: 26px 26px; mask-image: radial-gradient(ellipse at top, black 40%, transparent 85%); -webkit-mask-image: radial-gradient(ellipse at top, black 40%, transparent 85%);"
        aria-hidden="true"
      ></div>
      <div
        class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-500/40 to-transparent"
        aria-hidden="true"
      ></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Editorial asymmetric header -->
        <div class="grid lg:grid-cols-12 gap-x-8 gap-y-8 items-end mb-14 lg:mb-16">
          <div class="lg:col-span-7 animate-on-scroll">
            <div class="flex items-center gap-3 mb-5">
              <span class="h-px w-10 bg-gold-500"></span>
              <span class="text-[11px] font-semibold tracking-[0.22em] uppercase text-navy-700">Πώς λειτουργεί</span>
            </div>
            <h2 class="font-heading text-[2.25rem] sm:text-5xl lg:text-[3.4rem] font-extrabold text-navy-900 leading-[1.05] tracking-tight">
              Από την υπαγόρευση στο myDATA<br/>
              <span class="whitespace-nowrap">
                σε
                <span class="relative inline-block">
                  <svg
                    class="absolute overflow-visible pointer-events-none"
                    style="left: -0.3em; top: -0.38em; width: calc(100% + 0.6em); height: calc(100% + 0.76em);"
                    viewBox="0 0 700 200"
                    fill="none"
                    preserveAspectRatio="none"
                    aria-hidden="true"
                  >
                    <path
                      d="M 40 116 C 22 58, 160 22, 288 18 C 416 14, 556 28, 660 56 C 692 72, 694 118, 652 148 C 568 186, 380 192, 232 184 C 112 176, 14 156, 18 110 C 22 72, 34 48, 56 34"
                      stroke="oklch(0.72 0.14 68)"
                      stroke-width="2.75"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      vector-effect="non-scaling-stroke"
                      fill="none"
                    ></path>
                  </svg>
                  <span class="relative">30 δευτερόλεπτα</span>
                </span>.
              </span>
            </h2>
          </div>
          <div class="lg:col-span-4 lg:col-start-9 lg:pb-3 animate-on-scroll" style="animation-delay: 140ms">
            <p class="text-text-muted text-lg leading-relaxed max-w-sm">
              Το γράφετε ή το υπαγορεύετε στα ελληνικά. Ο βοηθός συμπληρώνει τα στοιχεία, υπολογίζει τον σωστό ΦΠΑ και σας παρουσιάζει το τιμολόγιο έτοιμο. Καμία φόρμα δεν χρειάζεται.
            </p>
          </div>
        </div>

        <!-- Demo frame with editorial corner brackets -->
        <div class="relative animate-on-scroll">
          <span aria-hidden="true" class="hidden lg:block absolute -top-3 -left-3 w-6 h-6 border-t-2 border-l-2 border-gold-500"></span>
          <span aria-hidden="true" class="hidden lg:block absolute -top-3 -right-3 w-6 h-6 border-t-2 border-r-2 border-gold-500"></span>
          <span aria-hidden="true" class="hidden lg:block absolute -bottom-3 -left-3 w-6 h-6 border-b-2 border-l-2 border-gold-500"></span>
          <span aria-hidden="true" class="hidden lg:block absolute -bottom-3 -right-3 w-6 h-6 border-b-2 border-r-2 border-gold-500"></span>
          <ChatDemo client:visible />
        </div>

        <!-- Numbered step strip — editorial footer -->
        <div class="mt-12 lg:mt-14 animate-on-scroll">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-5 sm:gap-4 py-5 border-t border-b border-border/70">
            <div class="flex items-center gap-3">
              <span class="font-heading text-xl font-light text-navy-300 tabular-nums leading-none">01</span>
              <span class="text-sm font-medium text-navy-800">Γράφετε ή υπαγορεύετε</span>
            </div>
            <span class="hidden sm:block h-px flex-1 mx-4 bg-border"></span>
            <div class="flex items-center gap-3">
              <span class="font-heading text-xl font-light text-navy-300 tabular-nums leading-none">02</span>
              <span class="text-sm font-medium text-navy-800">Εσείς επιβεβαιώνετε</span>
            </div>
            <span class="hidden sm:block h-px flex-1 mx-4 bg-border"></span>
            <div class="flex items-center gap-3">
              <span class="font-heading text-xl font-light text-gold-600 tabular-nums leading-none">03</span>
              <span class="text-sm font-medium text-navy-800">Αποστέλλεται στο myDATA</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- Demos gallery CTA — editorial dark banner -->
    <section
      data-nav-theme="dark"
      class="relative bg-navy-900 text-white overflow-hidden"
    >
      <!-- Dotted grid texture -->
      <div
        class="absolute inset-0 opacity-40 pointer-events-none"
        style="background-image: radial-gradient(circle, oklch(1 0 0 / 0.15) 1px, transparent 1px); background-size: 28px 28px; mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%); -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);"
        aria-hidden="true"
      ></div>
      <!-- Top and bottom gold hairlines -->
      <div
        class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-500/60 to-transparent"
        aria-hidden="true"
      ></div>
      <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-500/60 to-transparent"
        aria-hidden="true"
      ></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-24">
        <div class="grid lg:grid-cols-12 gap-x-10 gap-y-10 items-center">
          <!-- Left: editorial copy -->
          <div class="lg:col-span-7 animate-on-scroll">
            <div class="flex items-center gap-3 mb-5">
              <span class="h-px w-10 bg-gold-500"></span>
              <span class="text-[11px] font-semibold tracking-[0.22em] uppercase text-gold-400">
                Διαδραστική περιήγηση
              </span>
            </div>
            <h2 class="font-heading text-[2rem] sm:text-4xl lg:text-[2.8rem] font-extrabold leading-[1.1] tracking-tight mb-5">
              Δείτε πώς θα λειτουργεί η
              <span class="text-gold-400">πλατφόρμα</span> στην καθημερινότητά σας.
            </h2>
            <p class="text-white/70 text-base sm:text-lg leading-relaxed max-w-xl">
              Δοκιμάστε τις βασικές λειτουργίες του kiros.gr μέσα από
              καθοδηγούμενους οδηγούς. Κάντε κλικ, προχωρήστε σε κάθε βήμα και
              δείτε την πλατφόρμα από μέσα. Χωρίς εγγραφή, χωρίς εγκατάσταση.
            </p>
          </div>

          <!-- Right: prominent gold CTA -->
          <div
            class="lg:col-span-5 flex flex-col lg:items-end gap-4 animate-on-scroll"
            style="animation-delay: 140ms"
          >
            <a
              href="/demos"
              class="group inline-flex items-center justify-center gap-3 w-full sm:w-auto px-8 py-4 rounded-[var(--radius-lg)] bg-gold-500 text-navy-950 text-base font-bold hover:bg-gold-400 shadow-lg hover:shadow-xl transition-all duration-200"
            >
              <span>Ξεκινήστε την περιήγηση</span>
              <svg
                class="w-5 h-5 transition-transform group-hover:translate-x-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2.5"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"
                />
              </svg>
            </a>
            <p class="text-xs text-white/50 lg:text-right">
              Χωρίς εγγραφή. Σε λίγα λεπτά.
            </p>
          </div>
        </div>
      </div>
    </section>

    <Analytics />
    <Compliance2026 />
    <DeepDive />
    <PocketAccountant />
    <Comparison />
    <Pricing />
    <Beta />
  </main>
  <Footer />
</Layout>
