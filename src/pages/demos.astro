---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ArcadeEmbed from "../components/ArcadeEmbed.astro";
import DemoSection from "../components/DemoSection.astro";
---

<Layout
  title="Περιήγηση στην πλατφόρμα | kiros.gr"
  description="Διαδραστική περιήγηση στο kiros.gr. Δείτε πώς θα λειτουργεί η τιμολόγηση με τεχνητή νοημοσύνη σε συνεργασία με το myDATA της ΑΑΔΕ, χωρίς εγγραφή."
>
  <Nav simple />
  <main>
    <!-- Header -->
    <section class="relative pt-28 pb-10 lg:pt-36 lg:pb-14 bg-navy-50/60 overflow-hidden">
      <div
        class="absolute inset-0 opacity-60 pointer-events-none"
        style="background-image: radial-gradient(circle, oklch(0.72 0.03 260 / 0.25) 1px, transparent 1px); background-size: 26px 26px; mask-image: radial-gradient(ellipse at top, black 40%, transparent 85%); -webkit-mask-image: radial-gradient(ellipse at top, black 40%, transparent 85%);"
        aria-hidden="true"
      ></div>
      <div
        class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-500/40 to-transparent"
        aria-hidden="true"
      ></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-12 gap-x-8 gap-y-6 items-end">
          <div class="lg:col-span-7 animate-on-scroll">
            <div class="flex items-center gap-3 mb-5">
              <span class="h-px w-10 bg-gold-500"></span>
              <span class="text-[11px] font-semibold tracking-[0.22em] uppercase text-navy-700">
                Διαδραστική περιήγηση
              </span>
            </div>
            <h1
              class="font-heading text-[2.25rem] sm:text-5xl lg:text-[3.4rem] font-extrabold text-navy-900 leading-[1.05] tracking-tight"
            >
              Περιηγηθείτε στο kiros.gr<br />
              πριν την πρώτη σας τιμολόγηση.
            </h1>
          </div>
          <div
            class="lg:col-span-4 lg:col-start-9 lg:pb-3 animate-on-scroll"
            style="animation-delay: 140ms"
          >
            <p class="text-text-muted text-lg leading-relaxed max-w-sm">
              Δοκιμάστε τις βασικές λειτουργίες μέσα από καθοδηγούμενους οδηγούς.
              Κάντε κλικ, προχωρήστε σε κάθε βήμα και δείτε την πλατφόρμα από μέσα.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Disclaimer banner -->
    <section class="relative bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 lg:py-7">
        <div
          class="relative rounded-[var(--radius-lg)] border border-gold-500/30 bg-gold-500/5 px-5 py-4 sm:px-6 sm:py-5"
          role="note"
          aria-label="Σημείωση σχετικά με την περιήγηση"
        >
          <div class="flex items-start gap-3 sm:gap-4">
            <div
              class="shrink-0 mt-0.5 w-8 h-8 rounded-full bg-gold-500/15 flex items-center justify-center"
              aria-hidden="true"
            >
              <svg
                class="w-4 h-4 text-gold-600"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-sm font-semibold text-navy-900 mb-1">
                Σημείωση για την περιήγηση
              </p>
              <p class="text-sm text-text-muted leading-relaxed">
                Οι οδηγοί που ακολουθούν αποτελούν προεπισκόπηση των δυνατοτήτων
                της πλατφόρμας και δεν αντιπροσωπεύουν απαραίτητα την τελική
                εμπειρία χρήστη. Το kiros.gr βρίσκεται σε ενεργό ανάπτυξη,
                επομένως η διεπαφή, οι λειτουργίες και η ροή εργασίας ενδέχεται να
                διαφοροποιηθούν στην τελική έκδοση.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Demos list -->
    <section class="relative bg-surface pb-24 lg:pb-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-20 lg:space-y-28">
        <DemoSection
          id="invoice-submission"
          eyebrow="Οδηγός 01"
          title="Δημιουργία και υποβολή τιμολογίου παροχής υπηρεσιών"
          description="Παρακολουθήστε ολόκληρη τη διαδρομή, από τη συμπλήρωση των στοιχείων έως την επιτυχή αποστολή στο myDATA της ΑΑΔΕ."
        >
          <ArcadeEmbed
            src="https://demo.arcade.software/wZflGQY96bSjncnlMQD7?embed&embed_mobile=tab&embed_desktop=inline&show_copy_link=true"
            title="Δημιουργία και Υποβολή Τιμολογίου Παροχής Υπηρεσιών στην ΑΑΔΕ"
          />
        </DemoSection>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
