---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import DemoGallery, { type DemoShot } from "../components/DemoGallery.astro";

const shots: DemoShot[] = [
  {
    src: "/demos/01-dashboard.png",
    alt: "Αρχική σελίδα του kiros.gr με δείκτες εσόδων, εξόδων και γραφήματα.",
    title: "Η εικόνα του μήνα σε μία ματιά",
    caption:
      "Έσοδα, έξοδα, ΦΠΑ, κερδοφορία και κορυφαίοι πελάτες, όλα σε μία οθόνη. Τα νούμερα ενημερώνονται αυτόματα από το myDATA.",
    span: "wide",
  },
  {
    src: "/demos/02-invoices-list.png",
    alt: "Λίστα πωλήσεων με MARK, ΑΑΔΕ χαρακτηρισμούς και κατάσταση πληρωμής.",
    title: "Πωλήσεις με MARK και κατάσταση",
    caption:
      "Κάθε εκδοθέν παραστατικό φέρει τον αριθμό MARK, τη σειρά και την κατάσταση πληρωμής του, χωρίς χειροκίνητη συμπλήρωση.",
  },
  {
    src: "/demos/11-invoice-detail.png",
    alt: "Καρτέλα τιμολογίου με στοιχεία εκδότη, λήπτη και αναλυτικές γραμμές.",
    title: "Καρτέλα τιμολογίου",
    caption:
      "Πλήρης ανάγνωση του παραστατικού με χαρακτηρισμούς Ε3, τρόπους πληρωμής και ενέργειες προς ΑΑΔΕ σε ένα κλικ.",
  },
  {
    src: "/demos/03-create-invoice.png",
    alt: "Φόρμα δημιουργίας νέου παραστατικού με πεδία ΑΦΜ και γραμμές.",
    title: "Δημιουργία παραστατικού",
    caption:
      "Επιλέγετε τύπο, συμπληρώνετε λήπτη με αναζήτηση ΑΦΜ και αποθηκεύετε. Ένα κουμπί υποβάλλει το παραστατικό στο myDATA.",
  },
  {
    src: "/demos/06-agent.png",
    alt: "Βοηθός AI με πεδίο εντολής σε φυσική γλώσσα για έκδοση τιμολογίου.",
    title: "Βοηθός AI σε φυσική γλώσσα",
    caption:
      "Περιγράφετε το παραστατικό με μία πρόταση. Ο βοηθός προσυμπληρώνει τα πεδία, επιβεβαιώνετε και φεύγει στην ΑΑΔΕ.",
  },
  {
    src: "/demos/04-customers.png",
    alt: "Λίστα πελατών με σύνολο εσόδων ανά πελάτη.",
    title: "Πελατολόγιο με τζίρο",
    caption:
      "Όλοι οι πελάτες σε μία λίστα, με σύνολο εσόδων και στοιχεία επικοινωνίας. Εμπλουτίζεται αυτόματα από τιμολόγια και ΑΦΜ.",
  },
  {
    src: "/demos/05-customer-detail.png",
    alt: "Καρτέλα πελάτη με γραφήματα και πρόσφατα τιμολόγια.",
    title: "Καρτέλα πελάτη",
    caption:
      "Μηνιαία έσοδα, κατανομή παραστατικών, ανεξόφλητα και πρόσφατη δραστηριότητα για κάθε πελάτη ξεχωριστά.",
  },
  {
    src: "/demos/08-expenses.png",
    alt: "Λίστα εξόδων με πηγή ΑΑΔΕ ή ιδιοκαταχώρηση και χαρακτηρισμούς.",
    title: "Έξοδα με πηγή και χαρακτηρισμό",
    caption:
      "Ληφθέντα παραστατικά από την ΑΑΔΕ μαζί με ιδιοκαταχωρήσεις. Κάθε εγγραφή φέρει ετικέτα ΑΑΔΕ ή Πρόχειρο.",
  },
  {
    src: "/demos/07-products.png",
    alt: "Κατάλογος προϊόντων και υπηρεσιών με τιμές και ΦΠΑ.",
    title: "Κατάλογος προϊόντων και υπηρεσιών",
    caption:
      "Αποθηκεύετε προϊόντα και υπηρεσίες με κωδικό, τιμή και ΦΠΑ. Επιλέγονται με αναζήτηση κατά την έκδοση.",
  },
  {
    src: "/demos/09-delivery-note-create.png",
    alt: "Φόρμα έκδοσης δελτίου αποστολής.",
    title: "Δελτίο αποστολής",
    caption:
      "Έκδοση δελτίων διακίνησης με στοιχεία οχήματος και διευθύνσεις φόρτωσης και παράδοσης, σε πλήρη συμμόρφωση με το myDATA.",
  },
  {
    src: "/demos/10-settings.png",
    alt: "Ρυθμίσεις προεπιλογών φόρμας και σειρών παραστατικών.",
    title: "Ρυθμίσεις και προεπιλογές",
    caption:
      "Ορίζετε προεπιλογές φόρμας, σειρές, πρότυπα και προτιμήσεις email ώστε κάθε νέο παραστατικό να ξεκινά σωστά.",
  },
];
---

<Layout
  title="Περιήγηση στην πλατφόρμα | kiros.gr"
  description="Στιγμιότυπα από την πλατφόρμα kiros.gr. Δείτε πώς μοιάζει η τιμολόγηση με τεχνητή νοημοσύνη σε συνεργασία με το myDATA της ΑΑΔΕ."
>
  <Nav simple />
  <main>
    <!-- Header -->
    <section class="relative pt-28 pb-10 lg:pt-36 lg:pb-14 bg-navy-50/60 overflow-hidden">
      <div
        class="absolute inset-0 opacity-60 pointer-events-none"
        style="background-image: radial-gradient(circle, oklch(0.72 0.03 260 / 0.25) 1px, transparent 1px); background-size: 26px 26px; mask-image: radial-gradient(ellipse at top, black 40%, transparent 85%); -webkit-mask-image: radial-gradient(ellipse at top, black 40%, transparent 85%);"
        aria-hidden="true"
      ></div>
      <div
        class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold-500/40 to-transparent"
        aria-hidden="true"
      ></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-12 gap-x-8 gap-y-6 items-end">
          <div class="lg:col-span-7 animate-on-scroll">
            <div class="flex items-center gap-3 mb-5">
              <span class="h-px w-10 bg-gold-500"></span>
              <span class="text-[11px] font-semibold tracking-[0.22em] uppercase text-navy-700">
                Στιγμιότυπα πλατφόρμας
              </span>
            </div>
            <h1
              class="font-heading text-[2.25rem] sm:text-5xl lg:text-[3.4rem] font-extrabold text-navy-900 leading-[1.05] tracking-tight"
            >
              Μια ματιά στο kiros.gr<br />
              πριν την πρώτη σας τιμολόγηση.
            </h1>
          </div>
          <div
            class="lg:col-span-4 lg:col-start-9 lg:pb-3 animate-on-scroll"
            style="animation-delay: 140ms"
          >
            <p class="text-text-muted text-lg leading-relaxed max-w-sm">
              Επιλεγμένα στιγμιότυπα από τις βασικές οθόνες της πλατφόρμας.
              Πατήστε σε οποιοδήποτε για μεγέθυνση.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Disclaimer banner -->
    <section class="relative bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 lg:py-7">
        <div
          class="relative rounded-[var(--radius-lg)] border border-gold-500/30 bg-gold-500/5 px-5 py-4 sm:px-6 sm:py-5"
          role="note"
          aria-label="Σημείωση σχετικά με τα στιγμιότυπα"
        >
          <div class="flex items-start gap-3 sm:gap-4">
            <div
              class="shrink-0 mt-0.5 w-8 h-8 rounded-full bg-gold-500/15 flex items-center justify-center"
              aria-hidden="true"
            >
              <svg
                class="w-4 h-4 text-gold-600"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-sm font-semibold text-navy-900 mb-1">
                Σημείωση για τα στιγμιότυπα
              </p>
              <p class="text-sm text-text-muted leading-relaxed">
                Οι εικόνες αποτελούν προεπισκόπηση των δυνατοτήτων της
                πλατφόρμας και δεν αντιπροσωπεύουν απαραίτητα την τελική
                εμπειρία χρήστη. Το kiros.gr βρίσκεται σε ενεργό ανάπτυξη,
                επομένως η διεπαφή, οι λειτουργίες και η ροή εργασίας ενδέχεται
                να διαφοροποιηθούν στην τελική έκδοση.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Gallery -->
    <section class="relative bg-surface pb-24 lg:pb-32 pt-10 lg:pt-14">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <DemoGallery shots={shots} />
      </div>
    </section>
  </main>
  <Footer />
</Layout>
